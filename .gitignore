# Light Transfer Skill - Git Ignore

# 运行日志与进度
logs/
completed.json
failed.json
*.log

# 输出目录（用户产生的图片结果）
outputs/

# 测试图片（用户自己提供真实图片）
pics/*.jpg
pics/*.jpeg
pics/*.png
pics/*.webp
!pics/.gitkeep

# Python 缓存
__pycache__/
*.py[cod]
*$py.class
*.so

# 虚拟环境
.venv/
venv/
ENV/

# IDE 配置
.idea/
.vscode/
*.swp
*.swo

# 配置文件（用户本地配置不应上传）
config.yaml
.env
.env.local

# OS 生成文件
.DS_Store
Thumbs.db

# 包管理
node_modules/
package-lock.json

# 其他
*.bak
*.tmp
